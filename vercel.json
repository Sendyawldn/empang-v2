{
    "version": 2,
    "builds": [
        {
            "src": "backend/public/index.php",
            "use": "vercel-php@0.7.2"
        },
        {
            "src": "frontend/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/backend/public/index.php"
        },
        {
            "source": "/storage/(.*)",
            "destination": "/backend/public/storage/$1"
        },
        {
            "source": "/(.*)\\.(js|css|svg|ico|png|jpg|jpeg|gif|woff|woff2|ttf|eot|json)$",
            "destination": "/frontend/$1.$2"
        },
        {
            "source": "/(.*)",
            "destination": "/frontend/index.html"
        }
    ]
}
