{
    "version": 2,
    "builds": [
        {
            "src": "api/index.php",
            "use": "vercel-php@0.9.0"
        },
        {
            "src": "frontend/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.php"
        },
        {
            "source": "/storage/(.*)",
            "destination": "/backend/public/storage/$1"
        },
        {
            "source": "/assets/(.*)",
            "destination": "/frontend/assets/$1"
        },
        {
            "source": "/vite.svg",
            "destination": "/frontend/vite.svg"
        },
        {
            "source": "/(.*)",
            "destination": "/frontend/index.html"
        }
    ]
}
