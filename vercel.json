{
    "version": 2,
    "builds": [
        {
            "src": "backend/public/index.php",
            "use": "vercel-php@0.7.2"
        },
        {
            "src": "frontend/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/backend/public/index.php"
        },
        {
            "src": "/storage/(.*)",
            "dest": "/backend/public/storage/$1"
        },
        {
            "src": "/(.*)\\.(js|css|svg|ico|png|jpg|jpeg|gif|woff|woff2|ttf|eot)$",
            "dest": "/frontend/dist/$1.$2"
        },
        {
            "src": "/(.*)",
            "dest": "/frontend/dist/index.html"
        }
    ]
}
